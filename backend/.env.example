# At least one key required. Both can be set — OpenAI tried first, Claude as fallback.
OPENAI_API_KEY=sk-...your-key-here...
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Mercadona Portal Clientes (optional — for automatic invoice requests)
# Register at: https://www.portalcliente.mercadona.es
MERCADONA_EMAIL=tu-email@ejemplo.com
MERCADONA_PASSWORD=tu-contraseña
